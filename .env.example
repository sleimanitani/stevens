# Postgres
POSTGRES_USER=assistant
POSTGRES_PASSWORD=change-me-locally
POSTGRES_DB=assistant
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Application DSN (agents, adapters connect here)
DATABASE_URL=postgresql://assistant:change-me-locally@postgres:5432/assistant

# Ollama (runs on host, not in docker)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3:30b-a3b-instruct

# Langfuse (observability)
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_DB_USER=langfuse
LANGFUSE_DB_PASSWORD=change-me-locally
LANGFUSE_DB=langfuse
LANGFUSE_NEXTAUTH_SECRET=change-me-locally-random-string
LANGFUSE_SALT=change-me-locally-random-string

# Gmail adapter public URL (set after `tailscale funnel --bg 8080`)
GMAIL_PUBLIC_URL=https://example.your-tailnet.ts.net

# Google Cloud (for Gmail Pub/Sub)
GOOGLE_CLOUD_PROJECT=
GMAIL_PUBSUB_TOPIC=projects/your-project/topics/gmail-push

# Paths
GMAIL_OAUTH_CLIENT_SECRETS=/app/secrets/gmail_oauth_client.json
WHATSAPP_AUTH_DIR=/app/whatsapp-auth
