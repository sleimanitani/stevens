# Stevens v0.10 — environment template for the native install path.
#
# After `uv run stevens bootstrap`, DATABASE_URL is managed for you in
# ~/.config/stevens/env (unix-socket peer auth, no password, no port
# exposed). You don't need to set it here unless you're overriding to
# point at a non-default Postgres.
#
# For the legacy docker-compose path (developer-only), see
# `dev/compose.yaml` — it embeds its own POSTGRES_* + LANGFUSE_* vars
# inline and isn't driven by this file.

# --- Local LLM (Ollama on host) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:30b-a3b-instruct

# --- Optional: log level ---
# STEVENS_LOG_LEVEL=INFO

# --- Optional: override sealed-store + audit + policy paths ---
# Defaults are fine for most installs. Bootstrap creates the dirs.
# STEVENS_SECURITY_SECRETS=/var/lib/stevens/secrets
# STEVENS_SECURITY_AUDIT_DIR=/var/lib/stevens/audit
# STEVENS_SECURITY_AGENTS=security/policy/agents.yaml
# STEVENS_SECURITY_POLICY=security/policy/capabilities.yaml
# STEVENS_SECURITY_SOCKET=/run/stevens/security.sock

# --- Optional: passphrase for non-interactive flows (CI, supervised automation) ---
# Don't set this in operator shells — `stevens passphrase remember` is the
# right surface for everyday use. STEVENS_PASSPHRASE bypasses the keyring
# and the prompt; use only when you understand the trade-off.
# STEVENS_PASSPHRASE=

# --- Channel-specific (typically set during channel onboarding) ---
# Gmail
# GMAIL_PUBLIC_URL=https://stevens.example.ts.net
# GOOGLE_CLOUD_PROJECT=stevens-personal
# GMAIL_PUBSUB_TOPIC=projects/stevens-personal/topics/gmail-push
# GMAIL_OAUTH_CLIENT_SECRETS=~/.config/stevens/gmail_oauth_client.json
#
# WhatsApp (legacy Baileys adapter)
# WHATSAPP_AUTH_DIR=~/.local/share/stevens/whatsapp-auth

# --- Developer-only: Langfuse observability ---
# Langfuse is a developer-time concern; it lives in dev/compose.yaml
# rather than under `stevens bootstrap`. Set these only if you've brought
# the dev compose stack up.
# LANGFUSE_HOST=http://localhost:3000
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
